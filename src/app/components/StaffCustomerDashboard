                <CheckCircle size={48} className="text-primary mx-auto mb-4" />
                <h3 style={{ fontFamily: "'Playfair Display', serif", fontWeight: 700, fontSize: "1.3rem" }} className="text-foreground mb-2">Booking Submitted!</h3>
                <p className="text-muted-foreground text-sm mb-2">Your booking is pending staff approval.</p>
                <p style={{ fontFamily: "'DM Mono', monospace" }} className="text-accent text-sm mb-6">Ref: {lastBookingId}</p>
                <div className="flex gap-3 justify-center">
                  <button onClick={() => { setTab("payment"); setPayStep("select"); }} className="bg-primary text-primary-foreground px-6 py-2 rounded-lg text-sm hover:opacity-90">Proceed to Payment</button>
                  <button onClick={() => { setBookingStep("form"); setSelected(null); setTab("browse"); }} className="border border-border text-foreground px-6 py-2 rounded-lg text-sm hover:bg-muted">Back to Browse</button>
