// LOGIN SCREEN
// ═══════════════════════════════════════════════════════════════════════════════
function LoginScreen({ onLogin }) {
  const [role, setRole] = useState("customer");
  const [name, setName] = useState("");
  const [password, setPassword] = useState("");
  const [error, setError] = useState("");

  const handle = () => {
    if (!name.trim()) { setError("Please enter your name."); return; }
    if (role === "staff" && password !== "staff123") { setError("Incorrect staff password."); return; }
    onLogin(role, name.trim());
  };

  return (
    <div style={{ fontFamily: "'Lato', sans-serif" }} className="min-h-screen bg-background flex items-center justify-center p-6">
      <div className="w-full max-w-sm">
        <div className="text-center mb-8">
          <div className="flex items-center justify-center gap-2 mb-3">
            <TreePine size={32} className="text-primary" />
          </div>
          <h1 style={{ fontFamily: "'Playfair Display', serif", fontWeight: 700, fontSize: "1.8rem" }} className="text-foreground">Perong Campsite</h1>
          <p className="text-muted-foreground text-sm mt-1">Sign in to continue</p>
        </div>
        <div className="bg-card border border-border rounded-2xl p-6 shadow-sm">
          <div className="flex rounded-lg overflow-hidden border border-border mb-5">
            {["customer", "staff"].map(r => (
              <button key={r} onClick={() => { setRole(r); setError(""); }}
                className={`flex-1 py-2.5 text-sm transition-colors capitalize ${role === r ? "bg-primary text-primary-foreground" : "text-muted-foreground hover:bg-muted"}`}>
                {r === "customer" ? "Guest" : "Staff"}
              </button>
            ))}
          </div>
          <div className="space-y-4">
            <div>
              <label className="block text-sm text-foreground mb-1">Your name</label>
              <input type="text" placeholder={role === "customer" ? "e.g. Amirah Hassan" : "e.g. Ahmad Razali"}
                value={name} onChange={e => { setName(e.target.value); setError(""); }}
                onKeyDown={e => e.key === "Enter" && handle()}
                className="w-full px-3 py-2 rounded-lg border border-border bg-input-background text-foreground text-sm focus:outline-none focus:ring-2 focus:ring-ring" />
            </div>
            {role === "staff" && (
              <div>
                <label className="block text-sm text-foreground mb-1">Staff password</label>
                <input type="password" placeholder="Enter password" value={password}
                  onChange={e => { setPassword(e.target.value); setError(""); }}
                  onKeyDown={e => e.key === "Enter" && handle()}
                  className="w-full px-3 py-2 rounded-lg border border-border bg-input-background text-foreground text-sm focus:outline-none focus:ring-2 focus:ring-ring" />
                <p className="text-xs text-muted-foreground mt-1">Demo password: staff123</p>
              </div>
            )}
            {error && <p className="text-xs text-destructive">{error}</p>}
            <button onClick={handle} className="w-full bg-primary text-primary-foreground py-2.5 rounded-lg text-sm hover:opacity-90 transition-opacity font-medium">
              Sign In
            </button>
          </div>
        </div>
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════════════════
// ROOT APP — shared state wired through here
// ═══════════════════════════════════════════════════════════════════════════════
export default function App() {
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(true);

  const [campsites, setCampsites] = useState(DEFAULT_CAMPSITES);
  const [bookings, setBookings] = useState(DEFAULT_BOOKINGS);
  const [payments, setPayments] = useState(DEFAULT_PAYMENTS);

  useEffect(() => {
    async function init() {
      const [c, b, p] = await Promise.all([
        loadFromStorage("campsites", DEFAULT_CAMPSITES),
        loadFromStorage("bookings", DEFAULT_BOOKINGS),
        loadFromStorage("payments", DEFAULT_PAYMENTS),
      ]);
      setCampsites(c);
      setBookings(b);
      setPayments(p);
      setLoading(false);
    }
    init();
  }, []);

  if (loading) {
    return (
      <div className="min-h-screen bg-background flex items-center justify-center">
        <div className="flex items-center gap-3 text-muted-foreground">
          <TreePine size={24} className="text-primary animate-pulse" />
          <span style={{ fontFamily: "'Playfair Display', serif" }}>Loading Perong Campsite…</span>
        </div>
      </div>
    );
  }

  if (!user) return <LoginScreen onLogin={(role, name) => setUser({ role, name })} />;

  const sharedProps = { campsites, setCampsites, bookings, setBookings, payments, setPayments };

  if (user.role === "staff") {
    return <StaffDashboard userName={user.name} onLogout={() => setUser(null)} {...sharedProps} />;
  }

  return <CustomerDashboard userName={user.name} onLogout={() => setUser(null)} {...sharedProps} />;
}
