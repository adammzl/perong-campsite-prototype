// ─── Storage helpers ──────────────────────────────────────────────────────────
async function loadFromStorage(key, defaultVal) {
  try {
    const res = await window.storage.get(key);
    return res ? JSON.parse(res.value) : defaultVal;
  } catch {
    return defaultVal;
  }
}
async function saveToStorage(key, val) {
  try { await window.storage.set(key, JSON.stringify(val)); } catch {}
}

// ─── Tiny helpers ─────────────────────────────────────────────────────────────
const statusColor = {
  Confirmed: "bg-primary/10 text-primary",
  Pending: "bg-accent/10 text-accent",
  Completed: "bg-muted text-muted-foreground",
  Rejected: "bg-destructive/10 text-destructive",
  Rescheduled: "bg-purple-100 text-purple-700",
  RescheduleAccepted: "bg-primary/10 text-primary",
};

function fmtDate(d) {
  if (!d) return "—";
  try { return new Date(d).toLocaleDateString("en-MY", { day: "numeric", month: "short", year: "numeric" }); } catch { return d; }
}

function nightsBetween(a, b) {
  if (!a || !b) return 1;
  return Math.max(1, Math.round((new Date(b) - new Date(a)) / 86400000));
}

